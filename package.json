{
  "name": "discord-tidal-rpc",
  "version": "1.0.0",
  "private": true,
  "description": "Shows your current Tidal track on Discord via eddyAPI",
  "scripts": {
    "start": "node index.js",
    "watch": "concurrently \"pnpm:build --watch\" pnpm:serve",
    "build": "rimraf ./dist && tsx esbuild.config.mts && node copy-dist.mjs",
    "serve": "http-server ./dist -p 3000 -s --cors -c-1"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "http-server": "^14.1.1",
    "luna": "github:Inrixia/TidaLuna",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
